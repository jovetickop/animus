# EditorConfig is awesome: https://EditorConfig.org

# 顶层配置文件
root = true

# 所有文件
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown 文件
[*.md]
trim_trailing_whitespace = false

# PowerShell 脚本
[*.ps1]
end_of_line = crlf

# Shell 脚本
[*.sh]
end_of_line = lf

# Python 文件
[*.py]
indent_style = space
indent_size = 4

# JSON/YAML/TOML
[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

# CMake
[CMakeLists.txt]
indent_style = space
indent_size = 2