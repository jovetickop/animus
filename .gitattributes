# 自动检测文本文件，统一为 LF
* text=auto

# Shell 脚本 - 必须 LF（跨平台 Unix shell 要求）
*.sh text eol=lf
*.bash text eol=lf

# PowerShell 脚本 - Windows 使用 CRLF
*.ps1 text eol=crlf
*.psd1 text eol=crlf
*.psm1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# 跨平台源文件 - LF
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# 二进制文件 - 不转换
*.png binary
*.jpg binary
*.pdf binary
*.exe binary
*.dll binary
*.ico binary