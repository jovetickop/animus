{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/clang-format.sh\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/clang-format.py\" 2>/dev/null || exit 0",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-all.py\" --file \"<path>\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/write-gate.sh\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/write-gate.py\" 2>/dev/null || exit 0",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-tool-use.sh\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-tool-use.py\" 2>/dev/null || exit 0",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.sh\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.py\" 2>/dev/null || exit 0",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-check.sh\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-check.py\" 2>/dev/null || exit 0",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
